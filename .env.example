# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
PORT=8000

# ─────────────────────────────────────────────
# Firebase
# ─────────────────────────────────────────────
# Option A — path to service account JSON file (local dev)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Option B — inline JSON content (CI/CD / Cloud Run / Secret Manager)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_PROJECT_ID=your-project-id

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
# REQUIRED in production — no hardcoded fallback
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ─────────────────────────────────────────────
# CORS — comma-separated list of allowed origins
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────
# Google AI
# ─────────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

# ─────────────────────────────────────────────
# AfroMessage (SMS)
# ─────────────────────────────────────────────
AFROMESSAGE_API_KEY=
AFROMESSAGE_SENDER_NAME=AfroMessage
